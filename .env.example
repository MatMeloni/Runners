# ============================================================
# Runners — variáveis de ambiente
# Copie para .env e preencha os valores reais.
# NUNCA commite o arquivo .env com valores reais.
# ============================================================

# ── Backend FastAPI ──────────────────────────────────────────
# Host e porta do servidor uvicorn (Docker Compose / dev local)
API_HOST=0.0.0.0
API_PORT=8000

# ── Banco de dados ───────────────────────────────────────────
# Supabase → Settings → Database → Connection string
# Use o Transaction Pooler (porta 6543) em redes sem IPv6
DATABASE_URL=postgresql://postgres:[SENHA]@[HOST].supabase.co:6543/postgres

# ── Supabase Auth ────────────────────────────────────────────
# Supabase → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=seu-jwt-secret-aqui

# ── CORS ─────────────────────────────────────────────────────
# Origens permitidas para chamar a API (separadas por vírgula)
# Desenvolvimento local: http://localhost:3000
# Produção: inclua a URL do Vercel
CORS_ORIGINS=http://localhost:3000

# ── Frontend Next.js ─────────────────────────────────────────
# URL da API acessível pelo BROWSER (não pelo container)
# Local: http://localhost:8000
# Produção: URL pública do Railway / Render / Fly.io
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://[PROJETO].supabase.co

# Supabase → Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# ── Portas Docker Compose ────────────────────────────────────
WEB_PORT=3000
STREAMLIT_PORT=8501
