# ============================================================
# Runners MVP - variaveis de ambiente (copie para .env)
# ============================================================

# API backend
API_HOST=0.0.0.0
API_PORT=8000

# Supabase (Postgres + Auth)
# Use o pooler (porta 6543), evitando conexao direta IPv6.
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-<region>.pooler.supabase.com:6543/postgres
SUPABASE_JWT_SECRET=<supabase-jwt-secret>
CORS_ORIGINS=http://localhost:3000,https://<seu-projeto-vercel>.vercel.app

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>

# Opcional (streamlit local)
WEB_PORT=3000
STREAMLIT_PORT=8501

# Opcional (tunnel estavel Cloudflare para apresentar em outras maquinas)
# Crie no Cloudflare Zero Trust e cole o token aqui.
CLOUDFLARE_TUNNEL_TOKEN=<cloudflare-tunnel-token>
